    "dev:next": "next dev",
    "dev:velite": "velite dev",
    "fmt": "biome check --write .",
    "lint": "biome check .",
    "fetch-content": "node --import=tsx ./scripts/fetch-content.ts",
    "start": "next start",
    "storybook": "storybook dev -p 6006 --no-open",
    "typecheck": "tsc --noEmit",
    "wrangler": "wrangler",
    "velite": "velite"
  },
