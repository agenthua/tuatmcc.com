---
import type { CollectionEntry } from "astro:content";
import Tag from "@components/Tag.astro";

export interface Props {
  data: CollectionEntry<"posts">["data"];
}

const { data } = Astro.props;
const { title, date, tags } = data;
const authors: string[] = data.author
  ? [data.author]
  : data.authors
    ? data.authors
    : [];
---

<div class="flex flex-col gap-2 lg:gap-4">
  <a
    href="/posts"
    class="w-fit cursor-pointer border-none bg-transparent p-0 text-left text-inherit hover:underline"
  >
    &larr; Back to posts
  </a>
  <h1 class="text-base-content text-4xl font-bold">{title}</h1>
  <time class="text-sm text-gray-500" datetime={date.toISOString()}>
    {
      date.toLocaleDateString("ja-JP", {
        year: "numeric",
        month: "2-digit",
        day: "2-digit",
      })
    }
  </time>
  {
    authors.length > 0 && (
      <div class="text-sm text-gray-500">
        {authors.map((author, index) => (
          <a href={`https://github.com/${author}`} class="hover:underline">
            @{author}
            {index < authors.length - 1 ? ", " : ""}
          </a>
        ))}
      </div>
    )
  }
  <div class="not-prose flex flex-wrap gap-1">
    {
      tags?.map((tag) => (
        <a href={`/posts/tags/${tag}`}>
          <Tag>{tag}</Tag>
        </a>
      ))
    }
  </div>
</div>
