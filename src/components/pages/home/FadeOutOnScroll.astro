---
export interface Props {
  class?: string;
}

const { class: className } = Astro.props;
---

<div class={className} data-fade-out-scroll>
  <slot />
</div>

<script>
  import { animate, scroll } from "motion";

  function initFadeOutOnScroll() {
    const elements = document.querySelectorAll("[data-fade-out-scroll]");

    elements.forEach((element) => {
      // 初期状態を設定（表示状態）
      animate(element, { opacity: 1 }, { duration: 0 });

      // スクロール進行度に基づいてopacityを制御
      scroll((progress, info) => {
        const scrollY = info.y.current;

        if (scrollY > 200) {
          // スクロール位置が200px以上でフェードアウト
          animate(element, { opacity: 0 }, { duration: 0.5 });
        } else {
          // スクロール位置が200px未満でフェードイン
          animate(element, { opacity: 1 }, { duration: 0.5 });
        }
      });
    });
  }

  // DOM読み込み完了時に初期化
  if (document.readyState === "loading") {
    document.addEventListener("DOMContentLoaded", initFadeOutOnScroll);
  } else {
    initFadeOutOnScroll();
  }

  // Astroのページ遷移時にも対応
  document.addEventListener("astro:page-load", initFadeOutOnScroll);
</script>
