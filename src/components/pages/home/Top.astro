---
import FadeOutOnScroll from "./FadeOutOnScroll.astro";
---

<div
  class="sticky top-0 z-[-1] flex h-svh w-full flex-col items-center justify-center"
>
  <FadeOutOnScroll class="flex flex-col items-center justify-center">
    <div class="relative">
      <div class="hidden flex-col items-center md:flex" data-logo-animation>
        <img
          width="320"
          height="320"
          src="/animated_mcc.webp"
          alt="MCC Logo"
          class="h-80 w-80"
        />
      </div>
      <div class="flex flex-col items-center md:hidden">
        <img
          width="320"
          height="320"
          src="/animated_mcc.webp"
          alt="MCC Logo"
          class="h-80 w-80"
        />
      </div>
      <div
        class="orbitron absolute top-1/2 left-1/2 hidden translate-x-[-25%] translate-y-[-50%] flex-col text-center text-[120px] font-bold tracking-wide text-[#0066cc] md:flex"
        data-mcc-text
      >
        MCC
      </div>
    </div>
    <div
      class="flex translate-0 flex-col text-center text-xl font-bold"
      data-subtitle
    >
      マイクロコンピュータークラブ
    </div>
    <div class="fixed bottom-0 p-4">
      <svg
        width="84"
        height="84"
        viewBox="0 0 400 400"
        fill="none"
        xmlns="http://www.w3.org/2000/svg"
        class="animate-bounce"
      >
        <title>svg</title>
        <path d="M200 397L400 250V253L200 400L0 253V250L200 397Z" fill="black"
        ></path>
        <path d="M199 0H201V300H199V0Z" fill="black"></path>
      </svg>
    </div>
  </FadeOutOnScroll>
</div>

<style>
  .orbitron {
    font-family: "Orbitron", monospace;
  }
</style>

<script>
  import { animate } from "motion";

  function initTopAnimations() {
    // ロゴアニメーション（デスクトップのみ）
    const logoElement = document.querySelector("[data-logo-animation]");
    if (logoElement) {
      // 初期状態を設定
      animate(logoElement, { x: 0, scale: 1 }, { duration: 0 });

      // アニメーションを実行
      setTimeout(() => {
        animate(
          logoElement,
          {
            x: -170,
            scale: 0.6,
          },
          {
            duration: 1,
          },
        );
      }, 3000);
    }

    // MCCテキストアニメーション
    const mccText = document.querySelector("[data-mcc-text]");
    if (mccText) {
      // 初期状態（非表示）
      animate(mccText, { opacity: 0 }, { duration: 0 });

      // 4秒後にフェードイン
      setTimeout(() => {
        animate(mccText, { opacity: 1 }, { duration: 1 });
      }, 4000);
    }

    // サブタイトルアニメーション
    const subtitle = document.querySelector("[data-subtitle]");
    if (subtitle) {
      // 初期状態（非表示）
      animate(subtitle, { opacity: 0 }, { duration: 0 });

      // 2秒後にフェードイン
      setTimeout(() => {
        animate(subtitle, { opacity: 1 }, { duration: 2 });
      }, 2000);
    }
  }

  // DOM読み込み完了時に初期化
  if (document.readyState === "loading") {
    document.addEventListener("DOMContentLoaded", initTopAnimations);
  } else {
    initTopAnimations();
  }

  // Astroのページ遷移時にも対応
  document.addEventListener("astro:page-load", initTopAnimations);
</script>
