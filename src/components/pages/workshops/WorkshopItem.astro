---
import type { CollectionEntry } from "astro:content";

export interface Props {
  workshop: CollectionEntry<"workshopCovers">;
}

const { workshop } = Astro.props;
const authors: string[] = workshop.data.author
  ? [workshop.data.author]
  : workshop.data.authors
    ? workshop.data.authors
    : [];
---

<article class="group h-fit cursor-pointer duration-200">
  <a
    href={`/workshops/${workshop.id}/${workshop.data.firstSlug}`}
    class:list={[
      "from-secondary to-primary relative block bg-gradient-to-b p-[2px] pl-2",
      "[clip-path:polygon(0_0,0_100%,calc(100%-40px)_100%,100%_calc(100%-40px),100%_0)]",
    ]}
  >
    <div
      class:list={[
        "bg-base-100 flex h-36 flex-col gap-2.5 p-3 duration-100",
        "[clip-path:polygon(0_0,0_calc(100%-20px),0_calc(100%-20px),0_100%,calc(100%-39.4px)_100%,100%_calc(100%-39.4px),100%_0)]",
        "group-hover:[clip-path:polygon(0_0,0_calc(100%-20px),200px_calc(100%-20px),220px_100%,calc(100%-39.4px)_100%,100%_calc(100%-39.4px),100%_0)]",
      ]}
    >
      <h2
        class="text-base-content line-clamp-2 text-base leading-6 font-semibold"
      >
        {workshop.data.title}
      </h2>

      <div class="text-base-content flex items-center gap-3 text-xs">
        <time
          datetime={workshop.data.date.toISOString()}
          class="whitespace-nowrap"
        >
          {
            workshop.data.date.toLocaleDateString("ja-JP", {
              year: "numeric",
              month: "2-digit",
              day: "2-digit",
            })
          }
        </time>
        {
          authors.length > 0 && (
            <span class="whitespace-nowrap">
              {authors.map((author, index) => (
                <span>
                  @{author}
                  {index < authors.length - 1 ? ", " : ""}
                </span>
              ))}
            </span>
          )
        }
      </div>
    </div>
    <div
      class="font-orbitron text-base-100 absolute bottom-0.5 left-4 flex w-0 items-baseline gap-2 text-xs tracking-wider duration-400 group-hover:w-48"
    >
      Details
      <hr class="border-base-100 flex-1 border-b" />
    </div>
  </a>
</article>

<style>
  .line-clamp-2 {
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }
</style>
