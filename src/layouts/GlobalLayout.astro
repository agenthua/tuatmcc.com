---
import { GOOGLE_ANALYTICS_ID } from "astro:env/client";
import NavDrawer from "../components/NavDrawer.astro";
import "../styles/global.css";
import ThemeContext from "@components/ThemeContext.astro";
import GoogleAnalytics from "../components/GoogleAnalytics.astro";

export type Props = {
  title: string;
  ogImage?: string;
};

const { title, ogImage = "https://tuatmcc.com/images/og-image.png" } =
  Astro.props;
---

<html lang="ja">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="apple-touch-icon" href="/apple-touch-icon.png" />
    <link rel="manifest" href="/site.webmanifest" />
    <title>{title}</title>
    {GOOGLE_ANALYTICS_ID && <GoogleAnalytics id={GOOGLE_ANALYTICS_ID} />}

    <meta property="og:title" content={title} />
    <meta property="og:url" content={Astro.site?.toString()} />
    <meta property="og:image" content={ogImage} />
    <meta property="og:type" content="website" />
    <meta property="twitter:card" content="summary_large_image" />
    <link rel="sitemap" href="/sitemap-index.xml" />
    <ThemeContext />
  </head>
  <body>
    <NavDrawer>
      <slot />
    </NavDrawer>
  </body>
</html>
